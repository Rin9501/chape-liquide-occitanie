---
import '../styles/global.css';
// TODO: ajouter N° agrément Sika quand confirmé lors du RDV du 1er juin
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chape Liquide Occitanie — Applicateur agréé Sika, Ariège</title>
  <meta name="description" content="Expert chape liquide ciment en Occitanie. Applicateur agréé Sika. Devis gratuit sous 48h, intervention dès 50m². Ariège (09), Aude (11), Haute-Garonne (31)." />
  <meta property="og:title" content="Chape Liquide Occitanie — Applicateur agréé Sika" />
  <meta property="og:description" content="Devis gratuit sous 48h. Intervention dès 50m². 14 villes Ariège, Aude, Haute-Garonne." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- ── SEO technique ── -->
  <link rel="canonical" href="https://chapeliquide-occitanie.fr/" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- ── Open Graph complet ── -->
  <meta property="og:url"        content="https://chapeliquide-occitanie.fr/" />
  <meta property="og:image"      content="https://chapeliquide-occitanie.fr/uploads/chape-suzuki-pamiers-vue-ensemble.jpeg" />
  <meta property="og:image:alt"  content="Chantier chape liquide ciment 320 m² à Pamiers, Ariège — Chape Liquide Occitanie" />
  <meta property="og:locale"     content="fr_FR" />
  <meta property="og:site_name"  content="Chape Liquide Occitanie" />

  <!-- ── Twitter / X Card ── -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Chape Liquide Occitanie — Applicateur agréé Sika, Ariège" />
  <meta name="twitter:description" content="Expert chape liquide ciment en Occitanie. Devis gratuit sous 48h. Ariège, Aude, Haute-Garonne." />
  <meta name="twitter:image"       content="https://chapeliquide-occitanie.fr/uploads/chape-suzuki-pamiers-vue-ensemble.jpeg" />

  <!-- ── JSON-LD : LocalBusiness (signal local fort) ── -->
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Chape Liquide Occitanie",
    "legalName": "EURL Balussou Cyril",
    "description": "Applicateur agréé Sika spécialisé en chape liquide ciment, ravoirage isolant et plancher chauffant en Occitanie. Zone d'intervention : Ariège (09), Aude (11) et Haute-Garonne (31).",
    "url": "https://chapeliquide-occitanie.fr",
    "telephone": "+33687613987",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Mirepoix",
      "postalCode": "09500",
      "addressRegion": "Ariège",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 43.0892,
      "longitude": 1.8726
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Ariège" },
      { "@type": "AdministrativeArea", "name": "Aude" },
      { "@type": "AdministrativeArea", "name": "Haute-Garonne" }
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Prestations chape liquide en Occitanie",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Chape liquide ciment", "description": "Chape fluide haute resistance, ideale pour locaux commerciaux, garages et planchers chauffants." } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ravoirage isolant", "description": "Mise a niveau et isolation thermique avant coulage de chape." } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Plancher chauffant hydraulique", "description": "Enrobage de serpentins hydrauliques avec chape liquide Sika." } }
      ]
    },
    "taxID": "533 165 684 00028",
    "priceRange": "EUR EUR",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "07:30",
        "closes": "18:00"
      }
    ],
    "image": "https://chapeliquide-occitanie.fr/uploads/chape-suzuki-pamiers-vue-ensemble.jpeg"
  }
  </script>

  <!-- ── JSON-LD : FAQPage (rich snippets Google — accordéon dans les SERPs) ── -->
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quel délai entre le coulage et la pose du carrelage ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "28 jours indicatifs pour la chape ciment. Nous vous transmettons le PV de mesure d'humidité avant la pose du revêtement."
        }
      },
      {
        "@type": "Question",
        "name": "Quel prix au m² en Occitanie en 2026 ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le tarif dépend de la surface, de l'épaisseur, du type de chape et de l'accessibilité du chantier. Chaque situation est différente : une petite surface ou un accès difficile coûte plus cher au m² qu'une grande surface ouverte. Devis gratuit et précis sous 48h, sans engagement."
        }
      },
      {
        "@type": "Question",
        "name": "Travaillez-vous avec les planchers chauffants ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, c'est même 70 % de notre activité. Nous intervenons après pose des nappes par votre plombier-chauffagiste, et nous coulons en respectant les épaisseurs d'enrobage prescrites par le fabricant (4 cm au-dessus du tube en général)."
        }
      },
      {
        "@type": "Question",
        "name": "Quel est votre délai de séchage avant circulation ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Circulation piétonne légère possible 24 à 48h après coulage. Charge lourde, échafaudage, pose des cloisons : 7 jours. Mise en chauffe progressive du plancher chauffant : J+21 minimum."
        }
      },
      {
        "@type": "Question",
        "name": "Comment se déroule une journée de coulage ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Arrivée de l'équipe et mise en place de la pompe Lancy entre 7h30 et 8h. Préparation des seuils et joints périphériques. Coulage et lissage barbotin par nos 2 applicateurs. Nous laissons le chantier balisé et propre."
        }
      },
      {
        "@type": "Question",
        "name": "Intervenez-vous sur les maisons individuelles ou seulement les chantiers pro ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Les deux. Maisons neuves, rénovations, locaux commerciaux, EHPAD, hôtels — nous intervenons sur tous types de chantiers dès 50 m² dans nos 14 villes. La surface minimale est liée au transport en camion-toupie, pas à une contrainte technique. Devis sur plan ou visite gratuite sans engagement."
        }
      }
    ]
  }
  </script>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════
     HEADER sticky
═══════════════════════════════════════════════════════ -->
<header class="site-header">
  <div class="header-logo">
    <div class="header-logo-mark">cl</div>
    <div class="leading-[1.05]">
      <div class="font-display font-bold text-[15px] tracking-tight2">Chape Liquide Occitanie</div>
      <div class="spec text-[10px] mt-[2px]">Applicateur agréé Sika · Ariège</div>
    </div>
  </div>

  <nav class="header-nav">
    {[
      { label: 'Expertise',            href: '#expertise' },
      { label: 'Services',             href: '#services' },
      { label: "Zones d'intervention", href: '#zones-intervention' },
      { label: 'Réalisations',         href: '#realisations' },
      { label: 'Guide gratuit',        href: '#guide-gratuit' },
      { label: 'Contact',              href: '#devis' },
    ].map(({ label, href }) => (
      <a href={href}>{label}</a>
    ))}
  </nav>

  <div class="header-cta">
    <a href="tel:0687613987" class="header-tel">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
      <div>
        <div class="spec text-[10px]">Devis téléphone</div>
        <div class="font-mono font-semibold text-[14px]">06 87 61 39 87</div>
      </div>
    </a>
    <a href="#devis" class="btn btn-primary py-3 px-[18px] text-[14px]">
      Devis gratuit <span class="arrow">→</span>
    </a>
  </div>
</header>

<main>

<!-- ═══════════════════════════════════════════════════════
     01 — HERO
═══════════════════════════════════════════════════════ -->
<section id="accueil" class="relative bg-bg">
  <div class="hero-grid grid grid-cols-[1fr_1.05fr] min-h-[720px] items-stretch">

    <!-- Left text panel -->
    <div class="flex flex-col justify-between relative p-5 md:p-[64px_64px_56px]">
      <span class="cross-mark top-10 right-10"></span>
      <div class="eyebrow"><span class="num">01</span>Accueil — Coulage chape liquide</div>

      <div>
        <h1 class="h-display hero-h1 text-[88px] mb-8">
          L'expertise chape liquide qui sécurise votre chantier en Occitanie.
        </h1>
        <p class="lead text-[21px] max-w-[520px] mb-10">
          Chape liquide ciment, planchers chauffants, ravoirage. Posés par des applicateurs agréés Sika. Devis sous 48h, intervention jusqu'à 1h30 autour de Mirepoix.
        </p>
        <div class="flex gap-[14px] items-center flex-wrap">
          <a href="#devis" class="btn btn-primary">
            Demander un devis gratuit <span class="arrow">→</span>
          </a>
          <a href="#guide-gratuit" class="btn btn-ghost-dark">
            Télécharger le guide chape <span class="arrow">↓</span>
          </a>
        </div>
      </div>

      <!-- Spec readout -->
      <div class="hero-stats grid grid-cols-3 border-t border-line pt-6">
        <div>
          <div class="spec mb-[6px]">Surface min.</div>
          <div class="font-mono text-[22px] font-medium tracking-tight2 text-ink">50 m²</div>
        </div>
        <div>
          <div class="spec mb-[6px]">Cadence</div>
          <div class="font-mono text-[22px] font-medium tracking-tight2 text-ink">800 m²/j</div>
        </div>
        <div>
          <div class="spec mb-[6px]">Délai devis</div>
          <div class="font-mono text-[22px] font-medium tracking-tight2 text-ink">&lt; 48 h</div>
        </div>
      </div>
    </div>

    <!-- Right image panel -->
    <div class="hero-img relative overflow-hidden bg-ink">
      <img src="/uploads/chape-suzuki-pamiers-vue-ensemble.jpeg" alt="Chape fluide ciment grand local commercial Pamiers Ariège"
        class="w-full h-full object-cover brightness-[0.92]" />
      <div class="absolute bottom-6 left-6 right-6 flex justify-between items-end text-white">
        <div class="inline-block px-[10px] py-[6px] bg-black/50 backdrop-blur-sm font-mono text-[11px] tracking-wide6 uppercase">
          Chantier · 320 m² · Pamiers (09)
        </div>
        <div class="spec text-white/70 text-[10px]">CLO · 2025</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     TRUST BAND — Sika + chiffres clés
═══════════════════════════════════════════════════════ -->
<section class="bg-ink text-white py-9 px-5 md:px-16">
  <div class="trust-grid grid grid-cols-[1.1fr_3fr] gap-16 items-center">

    <!-- Badge Sika -->
    <div class="flex items-center gap-[18px] px-[18px] py-[14px] border border-white/[0.18] rounded-[3px]">
      <div class="w-14 h-14 bg-[#FFCC00] rounded-[2px] flex items-center justify-center font-display font-black text-[19px] text-black tracking-tight2 shrink-0">
        Sika
      </div>
      <div>
        <div class="spec text-white/55 text-[10px] mb-1">Certification</div>
        <div class="font-display font-semibold text-[15px] leading-[1.2]">
          Applicateur agréé Sika<br />
          <span class="mono text-[12px] text-white/60 font-normal">
            Ariège · Occitanie
          </span>
        </div>
      </div>
    </div>

    <!-- Chiffres -->
    <div class="trust-numbers grid grid-cols-4 gap-8">
      {[
        { val: '480+',    label: 'Chantiers livrés' },
        { val: '90 000+', label: 'm² coulés' },
        { val: '10 ans',  label: "d'expérience chape" },
        { val: '48 h',    label: 'Délai devis garanti' },
      ].map(({ val, label }) => (
        <div>
          <div class="font-display font-bold text-[38px] tracking-tight3 leading-none">{val}</div>
          <div class="spec text-white/55 mt-2 text-[11px]">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     02 — POURQUOI NOUS
═══════════════════════════════════════════════════════ -->
<section class="section-pad relative bg-bg py-[120px] px-16 pb-[100px]" id="expertise">
  <span class="cross-mark top-[60px] left-16"></span>
  <span class="cross-mark top-[60px] right-16"></span>

  <div class="split-2col grid grid-cols-[0.85fr_2fr] gap-20 mb-[72px]">
    <div>
      <div class="eyebrow"><span class="num">02</span>Pourquoi nous</div>
      <h2 class="h-section text-[56px] mt-6">
        Quatre raisons de signer avec nous, pas avec un autre.
      </h2>
    </div>
    <div class="split-2col-lead pt-12">
      <p class="lead text-[19px] max-w-[540px]">
        On ne fait que de la chape liquide. Pas de la maçonnerie, pas du carrelage, pas du second œuvre généraliste. Cette spécialisation, c'est ce qui sécurise votre planning et votre planéité.
      </p>
    </div>
  </div>

  <div class="reasons-grid grid grid-cols-4">
    {[
      { n:'01', title:'Applicateur agréé Sika', body:'La majorité des artisans Ariège travaillent en Lafarge. Nous coulons en Sika Agilia : garantie procédé, traçabilité produit, PV de chantier transmis.', tag:'Différenciation' },
      { n:'02', title:'Devis sous 48 h ouvrées', body:'Mesure des cotes sur plan ou visite gratuite si chantier dans nos 14 villes. Vous recevez le devis ferme et détaillé sous 48 heures, pas un mois plus tard.', tag:'Engagement' },
      { n:'03', title:"Cadence jusqu'à 800 m²/jour", body:"Pompe Lancy professionnelle, livraison en camion toupie, équipe de 2 applicateurs. Sur les grandes surfaces (>300 m²), le coulage s'enchaîne sans rupture de charge.", tag:'Capacité' },
      { n:'04', title:'1h30 autour de Mirepoix', body:'14 villes desservies en Ariège, Aude et Haute-Garonne. Pas de surcoût déplacement dans la zone. Étude possible au-delà sur demande.', tag:'Couverture' },
    ].map((it, i) => (
      <div class={`reason-card bg-bg-warm flex flex-col justify-between min-h-[320px] p-[32px_28px_28px] border border-line${i > 0 ? ' border-l-0' : ''}`}>
        <div>
          <div class="flex justify-between items-baseline mb-7">
            <span class="font-mono font-medium text-accent text-[13px]">{it.n}</span>
            <span class="spec text-[9px]">{it.tag}</span>
          </div>
          <h3 class="font-display font-bold text-[22px] tracking-tight2 leading-[1.1] mb-4">{it.title}</h3>
          <p class="text-[14px] leading-[1.55] text-ink-soft">{it.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     03 — NOS SERVICES
═══════════════════════════════════════════════════════ -->
<section id="services" class="section-pad bg-bg-deep py-[120px] px-16 pb-[100px]">
  <div class="split-2col grid grid-cols-[0.85fr_2fr] gap-20 mb-16 items-end">
    <div>
      <div class="eyebrow"><span class="num">03</span>Nos services</div>
      <h2 class="h-section text-[56px] mt-6">Quatre prestations, un seul applicateur.</h2>
    </div>
    <div class="pb-3">
      <a href="#expertise" class="font-display font-semibold text-[15px] border-b border-ink pb-1">
        Voir le dossier technique complet <span class="font-mono">→</span>
      </a>
    </div>
  </div>

  <div class="services-grid grid grid-cols-2 gap-6">
    {[
      { n:'01', title:'Chape liquide ciment', desc:'Haute résistance mécanique. Idéale pour locaux humides, garages, sous-sols, surfaces commerciales.', specs:['Résistance C20 / C25','Séchage 21-28 j',"Jusqu'à 800 m²/j"], img:'/uploads/coulage-villeneuve-dolmes-salon.jpeg', imgAlt:"Coulage chape liquide ciment en salon — Villeneuve-d'Olmes, Ariège (09)" },
      { n:'02', title:'Ravoirage isolant', desc:'Mise à niveau et passage des réseaux. Préparation propre avant chape liquide.', specs:['Billes PSE / liège','Épaisseur 4-15 cm','Compatible RE2020'], img:'/uploads/ravoirage-mirepoix-gaines.jpeg', imgAlt:'Ravoirage isolant avec passage de gaines chauffantes — Mirepoix, Ariège (09)' },
      { n:'03', title:'Plancher chauffant', desc:'Enrobage des serpentins hydrauliques avec transmission thermique optimale.', specs:['Chape ciment Sika','λ 1,8 W/m·K','Mise en chauffe J+21'], img:'/uploads/plancher-chauffant-montgaillard.jpeg', imgAlt:'Enrobage plancher chauffant hydraulique avec chape Sika — Montgaillard, Ariège (09)' },
    ].map((s) => (
      <a href={`#service-${s.n}`} class="service-card bg-bg-warm grid grid-cols-2 border border-line overflow-hidden min-h-[320px]">
        <div class="service-inner flex flex-col justify-between p-[32px_32px_28px]">
          <div>
            <div class="flex justify-between items-baseline mb-6">
              <span class="font-mono text-accent text-[13px] font-medium">Service · {s.n}</span>
              <span class="font-mono text-ink-mute text-[16px]">→</span>
            </div>
            <h3 class="font-display font-bold text-[30px] tracking-[-0.025em] leading-[1.05] mb-4">{s.title}</h3>
            <p class="text-[14px] leading-[1.55] text-ink-soft">{s.desc}</p>
          </div>
          <div class="flex flex-col gap-[6px] mt-6 border-t border-dashed border-line pt-4">
            {s.specs.map((sp) => (
              <div class="flex justify-between items-baseline">
                <span class="spec text-[10px]">{sp}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="service-img bg-ink overflow-hidden">
          <img src={s.img} alt={s.imgAlt} loading="lazy" class="w-full h-full object-cover" />
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     04 — GUIDE GRATUIT (lead magnet)
═══════════════════════════════════════════════════════ -->
<section id="guide-gratuit" class="section-pad relative bg-ink text-white py-[100px] px-16">
  <div class="ebook-grid grid grid-cols-[1.3fr_1fr] gap-20 items-center">
    <div>
      <div class="eyebrow on-dark"><span class="num">04</span>Guide gratuit · Édition 2026</div>
      <h2 class="h-section text-[56px] mt-6 mb-7 text-white">
        Chape liquide : le guide pour choisir sans se tromper.
      </h2>
      <p class="font-display text-[18px] leading-[1.4] text-white/[0.72] max-w-[540px] mb-9">
        8 chapitres, 12 minutes de lecture. Prix réels au m² en 2026, les 5 erreurs classiques chiffrées, checklist avant coulage, tout ce qu'il faut savoir avant de commander une chape.
      </p>
      <form class="flex gap-3 items-stretch max-w-[520px] mb-5" action="/api/ebook" method="POST">
        <input name="email" type="email" placeholder="votre@email.fr" required
          class="flex-1 min-w-0 px-[18px] py-4 bg-transparent border border-white/25 text-white font-display text-[15px]" />
        <button type="submit" class="btn btn-primary px-[22px] py-4">
          Recevoir le PDF <span class="arrow">→</span>
        </button>
      </form>
      <div class="spec text-[--on-dark-mute] text-[10px]">
        Aucun spam. Désinscription en 1 clic. Document hébergé en France.
      </div>
    </div>

    <!-- Mockup PDF 3D CSS — les transforms complexes restent en style inline (pas de classe Tailwind équivalente) -->
    <div class="ebook-mockup relative h-[480px] [perspective:2000px]">
      <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%) rotateY(-18deg) rotateX(4deg) rotateZ(-3deg);transform-style:preserve-3d;width:290px;height:410px;background:var(--bg-warm);box-shadow:40px 40px 80px rgba(0,0,0,0.5),-2px 0 0 rgba(0,0,0,0.4)"
        class="flex flex-col p-[34px_30px]">
        <div class="border-l-[3px] border-accent pl-[14px] mb-9">
          <div class="spec text-[9px] text-accent mb-1">Guide pratique · 2026</div>
          <div class="spec text-[9px] text-ink-mute">Chape Liquide Occitanie</div>
        </div>
        <h3 class="font-display font-bold text-[28px] tracking-[-0.025em] leading-[1.05] text-ink mb-auto">
          Chape liquide : choisir sans se tromper.
        </h3>
        <div class="mt-auto">
          <div class="hr-tech mb-3"></div>
          <div class="flex justify-between items-baseline">
            <div class="spec text-[9px]">8 chapitres · 48 pages</div>
            <div class="font-mono text-[11px] text-ink">FR · PDF</div>
          </div>
        </div>
      </div>
      <div style="position:absolute;left:calc(50% + 6px);top:calc(50% + 8px);transform:translate(-50%,-50%) rotateY(-18deg) rotateX(4deg) rotateZ(-3deg);width:290px;height:410px;z-index:-1"
        class="bg-bg-deep opacity-40"></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     05 — RÉALISATIONS
═══════════════════════════════════════════════════════ -->
<section id="realisations" class="section-pad bg-bg py-[120px] px-16 pb-[100px]">
  <div class="split-2col grid grid-cols-[0.85fr_2fr] gap-20 mb-16 items-end">
    <div>
      <div class="eyebrow"><span class="num">05</span>Réalisations</div>

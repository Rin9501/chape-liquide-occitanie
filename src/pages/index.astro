---
import '../styles/global.css';
// TODO: ajouter N° agrément Sika quand confirmé lors du RDV du 1er juin
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chape Liquide Occitanie — Applicateur agréé Sika, Ariège</title>
  <meta name="description" content="Expert chape liquide ciment en Occitanie. Applicateur agréé Sika. Devis gratuit sous 48h, intervention dès 50m². Ariège (09), Aude (11), Haute-Garonne (31)." />
  <meta property="og:title" content="Chape Liquide Occitanie — Applicateur agréé Sika" />
  <meta property="og:description" content="Devis gratuit sous 48h. Intervention dès 50m². 14 villes Ariège, Aude, Haute-Garonne." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ═══════════════════════════════════════════════════════
     HEADER sticky
═══════════════════════════════════════════════════════ -->
<header class="site-header">
  <div class="header-logo">
    <div class="header-logo-mark">cl</div>
    <div style="line-height:1.05">
      <div style="font-family:var(--f-display);font-weight:700;font-size:15px;letter-spacing:-0.02em">Chape Liquide Occitanie</div>
      <div class="spec" style="font-size:10px;margin-top:2px">Applicateur agréé Sika · Ariège</div>
    </div>
  </div>

  <nav class="header-nav">
    {['Expertise','Services','Zones d\'intervention','Réalisations','Guide gratuit','Contact'].map((item) => (
      <a href={`#${item.toLowerCase().replace(/[\s']/g,'-')}`}>{item}</a>
    ))}
  </nav>

  <div class="header-cta">
    <a href="tel:0687613987" class="header-tel">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
      <div>
        <div class="spec" style="font-size:10px">Devis téléphone</div>
        <div style="font-family:var(--f-mono);font-weight:600;font-size:14px">06 87 61 39 87</div>
      </div>
    </a>
    <a href="#devis" class="btn btn-primary" style="padding:12px 18px;font-size:14px">
      Devis gratuit <span class="arrow">→</span>
    </a>
  </div>
</header>

<main>

<!-- ═══════════════════════════════════════════════════════
     01 — HERO
═══════════════════════════════════════════════════════ -->
<section id="accueil" style="position:relative;background:var(--bg)">
  <div class="hero-grid" style="display:grid;grid-template-columns:1fr 1.05fr;min-height:720px;align-items:stretch">

    <!-- Left text panel -->
    <div style="padding:64px 64px 56px;display:flex;flex-direction:column;justify-content:space-between;position:relative">
      <span class="cross-mark" style="top:40px;right:40px"></span>
      <div class="eyebrow"><span class="num">01</span>Accueil — Coulage chape liquide</div>

      <div>
        <h1 class="h-display hero-h1" style="font-size:88px;margin-bottom:32px">
          L'expertise chape liquide qui sécurise votre chantier en Occitanie.
        </h1>
        <p class="lead" style="font-size:21px;max-width:520px;margin-bottom:40px">
          Chape liquide ciment, planchers chauffants, ravoirage. Posés par des applicateurs agréés Sika. Devis sous 48h, intervention jusqu'à 1h30 autour de Mirepoix.
        </p>
        <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap">
          <a href="#devis" class="btn btn-primary">
            Demander un devis gratuit <span class="arrow">→</span>
          </a>
          <a href="#guide-gratuit" class="btn btn-ghost-dark">
            Télécharger le guide chape <span class="arrow">↓</span>
          </a>
        </div>
      </div>

      <!-- Spec readout -->
      <div class="hero-stats" style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid var(--line);padding-top:24px">
        <div>
          <div class="spec" style="margin-bottom:6px">Surface min.</div>
          <div style="font-family:var(--f-mono);font-size:22px;font-weight:500;letter-spacing:-0.02em;color:var(--ink)">50 m²</div>
        </div>
        <div>
          <div class="spec" style="margin-bottom:6px">Cadence</div>
          <div style="font-family:var(--f-mono);font-size:22px;font-weight:500;letter-spacing:-0.02em;color:var(--ink)">800 m²/j</div>
        </div>
        <div>
          <div class="spec" style="margin-bottom:6px">Délai devis</div>
          <div style="font-family:var(--f-mono);font-size:22px;font-weight:500;letter-spacing:-0.02em;color:var(--ink)">&lt; 48 h</div>
        </div>
      </div>
    </div>

    <!-- Right image panel -->
    <div class="hero-img" style="position:relative;overflow:hidden;background:var(--ink)">
      <img src="/uploads/chape-suzuki-pamiers-vue-ensemble.jpeg" alt="Chape fluide ciment grand local commercial Pamiers Ariège"
        style="width:100%;height:100%;object-fit:cover;filter:brightness(0.92)" />
      <div style="position:absolute;bottom:24px;left:24px;right:24px;display:flex;justify-content:space-between;align-items:flex-end;color:#fff">
        <div style="display:inline-block;padding:6px 10px;background:rgba(0,0,0,0.5);backdrop-filter:blur(8px);font-family:var(--f-mono);font-size:11px;letter-spacing:0.06em;text-transform:uppercase">
          Chantier · 320 m² · Pamiers (09)
        </div>
        <div class="spec" style="color:rgba(255,255,255,0.7);font-size:10px">CLO · 2025</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     TRUST BAND — Sika + chiffres clés
═══════════════════════════════════════════════════════ -->
<section style="background:var(--ink);color:#fff;padding:36px 64px">
  <div class="trust-grid" style="display:grid;grid-template-columns:1.1fr 3fr;gap:64px;align-items:center">

    <!-- Badge Sika -->
    <div style="display:flex;align-items:center;gap:18px;padding:14px 18px;border:1px solid rgba(255,255,255,0.18);border-radius:3px">
      <div style="width:56px;height:56px;background:#FFCC00;border-radius:2px;display:flex;align-items:center;justify-content:center;font-family:var(--f-display);font-weight:900;font-size:19px;color:#000;letter-spacing:-0.02em;flex-shrink:0">
        Sika
      </div>
      <div>
        <div class="spec" style="color:rgba(255,255,255,0.55);font-size:10px;margin-bottom:4px">Certification</div>
        <div style="font-family:var(--f-display);font-weight:600;font-size:15px;line-height:1.2">
          Applicateur agréé Sika<br />
          <span class="mono" style="font-size:12px;color:rgba(255,255,255,0.6);font-weight:400">
            Ariège · Occitanie
          </span>
        </div>
      </div>
    </div>

    <!-- Chiffres -->
    <div class="trust-numbers" style="display:grid;grid-template-columns:repeat(4,1fr);gap:32px">
      <div>
        <div style="font-family:var(--f-display);font-weight:700;font-size:38px;letter-spacing:-0.03em;line-height:1">480+</div>
        <div class="spec" style="color:rgba(255,255,255,0.55);margin-top:8px;font-size:11px">Chantiers livrés</div>
      </div>
      <div>
        <div style="font-family:var(--f-display);font-weight:700;font-size:38px;letter-spacing:-0.03em;line-height:1">90 000+</div>
        <div class="spec" style="color:rgba(255,255,255,0.55);margin-top:8px;font-size:11px">m² coulés</div>
      </div>
      <div>
        <div style="font-family:var(--f-display);font-weight:700;font-size:38px;letter-spacing:-0.03em;line-height:1">10 ans</div>
        <div class="spec" style="color:rgba(255,255,255,0.55);margin-top:8px;font-size:11px">d'expérience chape</div>
      </div>
      <div>
        <div style="font-family:var(--f-display);font-weight:700;font-size:38px;letter-spacing:-0.03em;line-height:1">48 h</div>
        <div class="spec" style="color:rgba(255,255,255,0.55);margin-top:8px;font-size:11px">Délai devis garanti</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     02 — POURQUOI NOUS
═══════════════════════════════════════════════════════ -->
<section class="section-pad" id="expertise" style="padding:120px 64px 100px;background:var(--bg);position:relative">
  <span class="cross-mark" style="top:60px;left:64px"></span>
  <span class="cross-mark" style="top:60px;right:64px"></span>

  <div class="split-2col" style="display:grid;grid-template-columns:0.85fr 2fr;gap:80px;margin-bottom:72px">
    <div>
      <div class="eyebrow"><span class="num">02</span>Pourquoi nous</div>
      <h2 class="h-section" style="font-size:56px;margin-top:24px">
        Quatre raisons de signer avec nous, pas avec un autre.
      </h2>
    </div>
    <div class="split-2col-lead" style="padding-top:48px">
      <p class="lead" style="font-size:19px;max-width:540px">
        On ne fait que de la chape liquide. Pas de la maçonnerie, pas du carrelage, pas du second œuvre généraliste. Cette spécialisation, c'est ce qui sécurise votre planning et votre planéité.
      </p>
    </div>
  </div>

  <div class="reasons-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0">
    {[
      { n:'01', title:'Applicateur agréé Sika', body:'La majorité des artisans Ariège travaillent en Lafarge. Nous coulons en Sika Agilia : garantie procédé, traçabilité produit, PV de chantier transmis.', tag:'Différenciation' },
      { n:'02', title:'Devis sous 48 h ouvrées', body:'Mesure des cotes sur plan ou visite gratuite si chantier dans nos 14 villes. Vous recevez le devis ferme et détaillé sous 48 heures, pas un mois plus tard.', tag:'Engagement' },
      { n:'03', title:'Cadence jusqu\'à 800 m²/jour', body:'Pompe Lancy professionnelle, livraison en camion toupie, équipe de 2 applicateurs. Sur les grandes surfaces (>300 m²), le coulage s\'enchaîne sans rupture de charge.', tag:'Capacité' },
      { n:'04', title:'1h30 autour de Mirepoix', body:'14 villes desservies en Ariège, Aude et Haute-Garonne. Pas de surcoût déplacement dans la zone. Étude possible au-delà sur demande.', tag:'Couverture' },
    ].map((it, i) => (
      <div class="reason-card" style={`padding:32px 28px 28px;border-left:${i===0?'1px solid var(--line)':'none'};border-right:1px solid var(--line);border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--bg-warm);min-height:320px;display:flex;flex-direction:column;justify-content:space-between`}>
        <div>
          <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:28px">
            <span style="font-family:var(--f-mono);font-weight:500;color:var(--accent);font-size:13px">{it.n}</span>
            <span class="spec" style="font-size:9px">{it.tag}</span>
          </div>
          <h3 style="font-family:var(--f-display);font-weight:700;font-size:22px;letter-spacing:-0.02em;line-height:1.1;margin-bottom:16px">{it.title}</h3>
          <p style="font-size:14px;line-height:1.55;color:var(--ink-soft)">{it.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     03 — NOS SERVICES
═══════════════════════════════════════════════════════ -->
<section id="services" class="section-pad" style="padding:120px 64px 100px;background:var(--bg-deep)">
  <div class="split-2col" style="display:grid;grid-template-columns:0.85fr 2fr;gap:80px;margin-bottom:64px;align-items:end">
    <div>
      <div class="eyebrow"><span class="num">03</span>Nos services</div>
      <h2 class="h-section" style="font-size:56px;margin-top:24px">Quatre prestations, un seul applicateur.</h2>
    </div>
    <div style="padding-bottom:12px">
      <a href="#expertise" style="font-family:var(--f-display);font-weight:600;font-size:15px;border-bottom:1px solid var(--ink);padding-bottom:4px">
        Voir le dossier technique complet <span style="font-family:var(--f-mono)">→</span>
      </a>
    </div>
  </div>

  <div class="services-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px">
    {[
      { n:'01', title:'Chape liquide ciment', desc:'Haute résistance mécanique. Idéale pour locaux humides, garages, sous-sols, surfaces commerciales.', specs:['Résistance C20 / C25','Séchage 21-28 j','Jusqu\'à 800 m²/j'], img:'/uploads/coulage-villeneuve-dolmes-salon.jpeg' },
      { n:'02', title:'Ravoirage isolant', desc:'Mise à niveau et passage des réseaux. Préparation propre avant chape liquide.', specs:['Billes PSE / liège','Épaisseur 4-15 cm','Compatible RE2020'], img:'/uploads/ravoirage-mirepoix-gaines.jpeg' },
      { n:'03', title:'Plancher chauffant', desc:'Enrobage des serpentins hydrauliques avec transmission thermique optimale.', specs:['Chape ciment Sika','λ 1,8 W/m·K','Mise en chauffe J+21'], img:'/uploads/plancher-chauffant-montgaillard.jpeg' },
    ].map((s) => (
      <a href={`#service-${s.n}`} class="service-card" style="background:var(--bg-warm);display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--line);overflow:hidden;min-height:320px">
        <div class="service-inner" style="padding:32px 32px 28px;display:flex;flex-direction:column;justify-content:space-between">
          <div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:24px">
              <span style="font-family:var(--f-mono);color:var(--accent);font-size:13px;font-weight:500">Service · {s.n}</span>
              <span style="font-family:var(--f-mono);color:var(--ink-mute);font-size:16px">→</span>
            </div>
            <h3 style="font-family:var(--f-display);font-weight:700;font-size:30px;letter-spacing:-0.025em;line-height:1.05;margin-bottom:16px">{s.title}</h3>
            <p style="font-size:14px;line-height:1.55;color:var(--ink-soft)">{s.desc}</p>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px;margin-top:24px;border-top:1px dashed var(--line);padding-top:16px">
            {s.specs.map((sp) => (
              <div style="display:flex;justify-content:space-between;align-items:baseline">
                <span class="spec" style="font-size:10px">{sp}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="service-img" style="background:var(--ink);overflow:hidden">
          <img src={s.img} alt={s.title} style="width:100%;height:100%;object-fit:cover" />
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     04 — GUIDE GRATUIT (lead magnet)
═══════════════════════════════════════════════════════ -->
<section id="guide-gratuit" class="section-pad" style="padding:100px 64px;background:var(--ink);color:#fff;position:relative">
  <div class="ebook-grid" style="display:grid;grid-template-columns:1.3fr 1fr;gap:80px;align-items:center">
    <div>
      <div class="eyebrow on-dark"><span class="num">04</span>Guide gratuit · Édition 2026</div>
      <h2 class="h-section" style="font-size:56px;margin-top:24px;margin-bottom:28px;color:#fff">
        Chape liquide : le guide pour choisir sans se tromper.
      </h2>
      <p style="font-family:var(--f-display);font-size:18px;line-height:1.4;color:rgba(255,255,255,0.72);max-width:540px;margin-bottom:36px">
        8 chapitres, 12 minutes de lecture. Prix réels au m² en 2026, les 5 erreurs classiques chiffrées, checklist avant coulage, tout ce qu'il faut savoir avant de commander une chape.
      </p>
      <form style="display:flex;gap:12px;align-items:stretch;max-width:520px;margin-bottom:20px" action="/api/ebook" method="POST">
        <input name="email" type="email" placeholder="votre@email.fr" required
          style="flex:1;padding:16px 18px;background:transparent;border:1px solid rgba(255,255,255,0.25);color:#fff;font-family:var(--f-display);font-size:15px" />
        <button type="submit" class="btn btn-primary" style="padding:16px 22px">
          Recevoir le PDF <span class="arrow">→</span>
        </button>
      </form>
      <div class="spec" style="color:var(--on-dark-mute);font-size:10px">
        Aucun spam. Désinscription en 1 clic. Document hébergé en France.
      </div>
    </div>

    <!-- Mockup PDF 3D CSS -->
    <div class="ebook-mockup" style="position:relative;height:480px;perspective:2000px">
      <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%) rotateY(-18deg) rotateX(4deg) rotateZ(-3deg);transform-style:preserve-3d;width:290px;height:410px;background:var(--bg-warm);box-shadow:40px 40px 80px rgba(0,0,0,0.5),-2px 0 0 rgba(0,0,0,0.4);padding:34px 30px;display:flex;flex-direction:column">
        <div style="border-left:3px solid var(--accent);padding-left:14px;margin-bottom:36px">
          <div class="spec" style="font-size:9px;color:var(--accent);margin-bottom:4px">Guide pratique · 2026</div>
          <div class="spec" style="font-size:9px;color:var(--ink-mute)">Chape Liquide Occitanie</div>
        </div>
        <h3 style="font-family:var(--f-display);font-weight:700;font-size:28px;letter-spacing:-0.025em;line-height:1.05;color:var(--ink);margin-bottom:auto">
          Chape liquide : choisir sans se tromper.
        </h3>
        <div style="margin-top:auto">
          <div class="hr-tech" style="margin-bottom:12px"></div>
          <div style="display:flex;justify-content:space-between;align-items:baseline">
            <div class="spec" style="font-size:9px">8 chapitres · 48 pages</div>
            <div style="font-family:var(--f-mono);font-size:11px;color:var(--ink)">FR · PDF</div>
          </div>
        </div>
      </div>
      <div style="position:absolute;left:calc(50% + 6px);top:calc(50% + 8px);transform:translate(-50%,-50%) rotateY(-18deg) rotateX(4deg) rotateZ(-3deg);width:290px;height:410px;background:var(--bg-deep);z-index:-1;opacity:0.4"></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     05 — RÉALISATIONS
═══════════════════════════════════════════════════════ -->
<section id="realisations" class="section-pad" style="padding:120px 64px 100px;background:var(--bg)">
  <div class="split-2col" style="display:grid;grid-template-columns:0.85fr 2fr;gap:80px;margin-bottom:64px;align-items:end">
    <div>
      <div class="eyebrow"><span class="num">05</span>Réalisations</div>
      <h2 class="h-section" style="font-size:56px;margin-top:24px">Cinq chantiers récents, photos réelles.</h2>
    </div>
    <div style="padding-bottom:12px">
      <p class="lead" style="font-size:18px;max-width:540px;margin-bottom:20px">
        Pas de visuels de catalogue ni de rendus 3D. Toutes les images de ce site sortent de nos camions, prises sur chantier au moment du coulage ou après séchage.
      </p>
      <a href="#realisations" style="font-family:var(--f-display);font-weight:600;font-size:15px;border-bottom:1px solid var(--ink);padding-bottom:4px">
        Voir tous les chantiers <span class="mono">→</span>
      </a>
    </div>
  </div>

  <div class="realisations-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px">
    {[
      { img:'/uploads/chape-suzuki-pamiers-vue-ensemble.jpeg', label:'Local commercial · 320 m²', loc:'Pamiers (09)', date:'2025', tech:'Chape ciment' },
      { img:'/uploads/coulage-villeneuve-dolmes-baie.jpeg',    label:'Maison neuve · 170 m²',   loc:'Villeneuve d\'Olmes (09)', date:'2025', tech:'Chape ciment' },
      { img:'/uploads/coulage-ouvrier-villeneuve-dolmes.jpeg', label:'Coulage en cours · 170 m²', loc:'Villeneuve d\'Olmes (09)', date:'2025', tech:'Chape ciment' },
      { img:'/uploads/preparation-tms-saverdun-kine.jpeg',     label:'Cabinet kiné · préparation', loc:'Saverdun (09)', date:'2025', tech:'Isolation TMS' },
      { img:'/uploads/chape-terminee-saverdun-kine.jpeg',      label:'Cabinet kiné · résultat',   loc:'Saverdun (09)', date:'2025', tech:'Ciment + TMS' },
      { img:'/uploads/ravoirage-mirepoix-gaines.jpeg',         label:'Ravoirage · 160 m²',       loc:'Mirepoix (09)', date:'2025', tech:'Ravoirage' },
    ].map((p, i) => (
      <a href="#realisations" style="display:block">
        <div style="background:var(--ink);aspect-ratio:4/5;overflow:hidden;margin-bottom:14px">
          <img src={p.img} alt={p.label} style="width:100%;height:100%;object-fit:cover" />
        </div>
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px">
          <span style="font-family:var(--f-mono);font-size:11px;color:var(--accent)">{String(i+1).padStart(2,'0')} / 06</span>
          <span class="spec" style="font-size:10px">{p.date}</span>
        </div>
        <h4 style="font-family:var(--f-display);font-weight:600;font-size:18px;letter-spacing:-0.015em;line-height:1.2;margin-bottom:4px">{p.label}</h4>
        <div style="font-size:13px;color:var(--ink-soft)">{p.loc} <span style="color:var(--ink-mute)">· {p.tech}</span></div>
      </a>
    ))}
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     06 — ZONE D'INTERVENTION (carte SVG)
═══════════════════════════════════════════════════════ -->
<section id="zones-d'intervention" class="section-pad" style="padding:120px 64px 100px;background:var(--bg-warm)">
  <div class="zone-grid" style="display:grid;grid-template-columns:0.9fr 1.6fr;gap:80px;align-items:center">
    <div>

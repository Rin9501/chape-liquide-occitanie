---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Guide reçu — Chape Liquide Occitanie</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href="https://chapeliquide-occitanie.fr/merci" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<header class="site-header">
  <a href="/" class="header-logo">
    <div class="header-logo-mark">cl</div>
    <div class="leading-[1.05]">
      <div class="font-display font-bold text-[15px] tracking-tight2">Chape Liquide Occitanie</div>
      <div class="spec text-[10px] mt-[2px]">Applicateur agréé Sika · Ariège</div>
    </div>
  </a>
  <div class="header-cta">
    <a href="tel:0687613987" class="header-tel">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
      <div>
        <div class="spec text-[10px]">Devis téléphone</div>
        <div class="font-mono font-semibold text-[14px]">06 87 61 39 87</div>
      </div>
    </a>
    <a href="/#devis" class="btn btn-primary py-3 px-[18px] text-[14px]">
      Devis gratuit <span class="arrow">→</span>
    </a>
  </div>
</header>

<main>
<section class="min-h-[80vh] flex items-center justify-center bg-bg px-6 py-24">
  <div class="max-w-[560px] text-center">

    <!-- Icône succès -->
    <div class="w-16 h-16 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center mx-auto mb-8">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C4522A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>

    <div class="eyebrow justify-center mb-4"><span class="num">✓</span>Guide envoyé</div>

    <h1 class="font-display font-bold text-[48px] tracking-[-0.025em] leading-[1.05] mb-6">
      Vérifiez votre boîte mail.
    </h1>

    <p class="font-display text-[18px] leading-[1.5] text-ink-soft max-w-[440px] mx-auto mb-6">
      Le guide <strong>« Chape liquide : choisir sans se tromper »</strong> est en route dans votre boîte mail.
    </p>
    <a href="/guide-chape-liquide-2026.pdf" download
       class="inline-flex items-center gap-2 bg-[#2C2C2C] text-white font-semibold text-[14px] px-6 py-4 rounded-[3px] mb-4 hover:opacity-90 transition-opacity">
      ⬇ Télécharger directement le PDF
    </a>
    <p class="text-[12px] text-ink-soft mb-8">Si vous ne recevez pas l'email dans 5 minutes, vérifiez vos courriers indésirables.</p>

    <div class="border-t border-line pt-8 mb-8">
      <p class="text-[14px] text-ink-soft mb-6">
        Pendant que vous attendez — besoin d'un devis rapide ?
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="/#devis" class="btn btn-primary py-4 px-6">
          Demander un devis gratuit <span class="arrow">→</span>
        </a>
        <a href="tel:0687613987" class="btn btn-ghost-dark py-4 px-6">
          <span class="mono">06 87 61 39 87</span>
        </a>
      </div>
    </div>

    <a href="/" class="spec text-[12px] border-b border-line pb-[2px]">
      ← Retour à l'accueil
    </a>

  </div>
</section>
</main>

<footer class="bg-dark text-white/40 py-6 px-8 text-center text-[12px]">
  © 2026 EURL Balussou Cyril · Chape Liquide Occitanie ·
  <a href="/mentions-legales" class="hover:text-white/70">Mentions légales</a>
</footer>

</body>
</html>
